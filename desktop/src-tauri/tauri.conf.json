{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLI4ALL Desktop",
  "version": "0.1.0",
  "identifier": "com.cli4all.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CLI4ALL Desktop",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 520,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
