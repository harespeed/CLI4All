{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLI4ALL",
  "version": "0.1.0",
  "identifier": "com.harespeed.cli4all",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CLI4ALL",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 520,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.png"
    ],
    "resources": {
      "../../data": "data"
    }
  }
}
